<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Renacer en Casa | Terapias de recuperacion para adultos mayores en Panama</title>
  <meta name="description" content="Terapias de recuperacion, estimulacion sensorial, drenaje linfatico, masaje terapeutico y acompanamiento a domicilio para adultos mayores y adultos en recuperacion en Ciudad de Panama. Promo junio: 50% en primera valoracion a domicilio con terapia de evaluacion.">
  <meta name="theme-color" content="#173b42">
  <meta property="og:title" content="Renacer en Casa | Terapias de recuperacion a domicilio">
  <meta property="og:description" content="Atencion con amor, tecnica y seguimiento para adultos mayores y adultos en recuperacion. San Francisco, Ciudad de Panama.">
  <meta property="og:image" content="renacer-assets/hero-terapia.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --ink: #173b42;
      --ink-2: #224c54;
      --muted: #60777c;
      --line: #d9e8e4;
      --sage: #7cb7a5;
      --sage-2: #dff1eb;
      --aqua: #2bb8b2;
      --coral: #e97862;
      --gold: #d1a955;
      --cream: #fff8ed;
      --rose: #fff0ec;
      --blue: #eaf5ff;
      --white: #ffffff;
      --soft: #f6fbf9;
      --shadow: 0 20px 54px rgba(23, 59, 66, .13);
      --shadow-soft: 0 12px 30px rgba(23, 59, 66, .08);
      --radius: 8px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Inter, Arial, sans-serif;
      color: var(--ink);
      background:
        linear-gradient(180deg, #f8fffd 0%, #ffffff 35%, #fffaf2 100%);
      overflow-x: hidden;
    }

    img,
    video {
      display: block;
      max-width: 100%;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    .container {
      width: min(1160px, calc(100% - 32px));
      margin: 0 auto;
    }

    .top-ribbon {
      color: white;
      background: linear-gradient(90deg, var(--ink), #2d6f6b);
      font-size: 13px;
      font-weight: 800;
    }

    .top-ribbon .container {
      min-height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-align: center;
    }

    .top-ribbon strong {
      color: #ffe7a4;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255, 255, 255, .88);
      border-bottom: 1px solid rgba(23, 59, 66, .08);
      backdrop-filter: blur(16px);
    }

    .nav {
      min-height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-weight: 900;
      color: var(--ink);
    }

    .brand-mark {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: white;
      background:
        linear-gradient(135deg, var(--sage), var(--aqua));
      box-shadow: 0 10px 22px rgba(43, 184, 178, .25);
      font-family: "Playfair Display", Georgia, serif;
      font-size: 25px;
    }

    .brand-text {
      display: grid;
      line-height: 1.1;
    }

    .brand-text small {
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .nav-links {
      display: none;
      align-items: center;
      gap: 16px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
    }

    .nav-links a:hover {
      color: var(--ink);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .btn {
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 0;
      border-radius: 999px;
      padding: 0 18px;
      font-weight: 900;
      text-align: center;
      cursor: pointer;
      transition:
        transform .18s ease,
        box-shadow .18s ease,
        background .18s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      color: white;
      background: linear-gradient(135deg, var(--coral), #cb5f9a);
      box-shadow: 0 16px 34px rgba(233, 120, 98, .24);
    }

    .btn-secondary {
      color: white;
      background: linear-gradient(135deg, var(--aqua), #2d8f8a);
      box-shadow: 0 16px 34px rgba(43, 184, 178, .24);
    }

    .btn-light {
      color: var(--ink);
      background: white;
      border: 1px solid var(--line);
      box-shadow: var(--shadow-soft);
    }

    .btn-ghost {
      color: var(--ink);
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(23, 59, 66, .12);
    }

    .hero {
      position: relative;
      padding: 34px 0 54px;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0 0 auto;
      height: 58%;
      background:
        radial-gradient(circle at 8% 10%, rgba(124, 183, 165, .22), transparent 32%),
        radial-gradient(circle at 92% 8%, rgba(233, 120, 98, .14), transparent 28%);
      pointer-events: none;
    }

    .hero-grid {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 24px;
      align-items: center;
    }

    .eyebrow {
      width: max-content;
      max-width: 100%;
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      border-radius: 999px;
      color: #216c68;
      background: var(--sage-2);
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .eyebrow::before {
      content: "";
      width: 22px;
      height: 2px;
      border-radius: 999px;
      background: var(--gold);
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1 {
      max-width: 850px;
      margin: 16px 0 16px;
      color: var(--ink);
      font-family: "Playfair Display", Georgia, serif;
      font-size: clamp(43px, 9vw, 86px);
      line-height: .96;
      letter-spacing: 0;
    }

    .lead {
      max-width: 760px;
      color: var(--muted);
      font-size: 18px;
      line-height: 1.68;
    }

    .hero-actions {
      display: grid;
      gap: 12px;
      margin-top: 22px;
    }

    .trust-row {
      display: grid;
      gap: 10px;
      margin-top: 24px;
    }

    .trust-pill {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border: 1px solid rgba(23, 59, 66, .12);
      border-radius: var(--radius);
      background: rgba(255, 255, 255, .84);
      box-shadow: var(--shadow-soft);
      color: var(--ink);
      font-size: 14px;
      font-weight: 800;
    }

    .trust-dot {
      width: 10px;
      height: 10px;
      flex: 0 0 auto;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--aqua), var(--coral));
      box-shadow: 0 0 0 5px rgba(43, 184, 178, .12);
    }

    .hero-card {
      overflow: hidden;
      border: 1px solid rgba(23, 59, 66, .12);
      border-radius: var(--radius);
      background: white;
      box-shadow: var(--shadow);
    }

    .hero-card img {
      width: 100%;
      aspect-ratio: 4 / 4.45;
      object-fit: cover;
    }

    .hero-card-body {
      display: grid;
      gap: 12px;
      padding: 18px;
    }

    .promo-box {
      display: grid;
      gap: 14px;
      margin-top: 20px;
      padding: 18px;
      border: 1px solid rgba(209, 169, 85, .4);
      border-radius: var(--radius);
      background:
        linear-gradient(135deg, rgba(255, 248, 237, .96), rgba(255, 255, 255, .96));
      box-shadow: var(--shadow-soft);
    }

    .promo-box strong {
      color: var(--ink);
      font-size: 16px;
      line-height: 1.45;
    }

    .countdown {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }

    .timebox {
      min-height: 76px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(209, 169, 85, .28);
      border-radius: var(--radius);
      background: white;
      text-align: center;
    }

    .timebox b {
      display: block;
      color: var(--ink);
      font-size: clamp(22px, 5vw, 34px);
      line-height: 1;
    }

    .timebox span {
      display: block;
      margin-top: 6px;
      color: #856d2e;
      font-size: 11px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .quick-routes {
      display: grid;
      gap: 10px;
    }

    .route-card {
      display: grid;
      gap: 8px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: white;
    }

    .route-card small {
      color: var(--sage);
      font-weight: 900;
      text-transform: uppercase;
    }

    .route-card b {
      color: var(--ink);
      font-size: 20px;
    }

    .section {
      padding: 58px 0;
    }

    .section-soft {
      background: rgba(246, 251, 249, .86);
    }

    .section-cream {
      background: rgba(255, 248, 237, .78);
    }

    .section-head {
      max-width: 850px;
      margin-bottom: 26px;
    }

    .section-head h2,
    .split h2,
    .form-panel h2 {
      margin: 12px 0 10px;
      color: var(--ink);
      font-family: "Playfair Display", Georgia, serif;
      font-size: clamp(32px, 7vw, 58px);
      line-height: 1.03;
      letter-spacing: 0;
    }

    .section-head p,
    .split p {
      color: var(--muted);
      font-size: 17px;
      line-height: 1.72;
    }

    .split {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 24px;
      align-items: center;
    }

    .grid-2,
    .grid-3,
    .grid-4,
    .blog-grid,
    .gallery-grid,
    .video-grid,
    .testimonial-grid,
    .equipment-grid,
    .faq-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 16px;
    }

    .card,
    .service-card,
    .therapy-card,
    .blog-card,
    .testimonial-card,
    .faq-item,
    .equipment-card,
    .step-card,
    .warning-card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: white;
      box-shadow: var(--shadow-soft);
      overflow: hidden;
    }

    .card-body,
    .service-card,
    .therapy-card,
    .blog-card,
    .testimonial-card,
    .faq-item,
    .equipment-card,
    .step-card,
    .warning-card {
      padding: 20px;
    }

    .card h3,
    .service-card h3,
    .therapy-card h3,
    .blog-card h3,
    .testimonial-card h3,
    .faq-item h3,
    .equipment-card h3,
    .step-card h3,
    .warning-card h3 {
      margin-bottom: 9px;
      color: var(--ink);
      font-size: 21px;
      line-height: 1.17;
    }

    .card p,
    .service-card p,
    .therapy-card p,
    .blog-card p,
    .testimonial-card p,
    .faq-item p,
    .equipment-card p,
    .step-card p,
    .warning-card p {
      margin-bottom: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.68;
    }

    .stat-band {
      padding: 28px 0;
      color: white;
      background: linear-gradient(135deg, var(--ink), #2e7774);
    }

    .stat-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 14px;
    }

    .stat {
      padding: 18px;
      border: 1px solid rgba(255, 255, 255, .18);
      border-radius: var(--radius);
      background: rgba(255, 255, 255, .08);
    }

    .stat b {
      display: block;
      color: white;
      font-family: "Playfair Display", Georgia, serif;
      font-size: 32px;
      line-height: 1;
    }

    .stat span {
      display: block;
      margin-top: 8px;
      color: rgba(255, 255, 255, .82);
      font-size: 14px;
      line-height: 1.5;
    }

    .image-frame {
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: white;
      box-shadow: var(--shadow);
    }

    .image-frame img {
      width: 100%;
      aspect-ratio: 4 / 3.35;
      object-fit: cover;
    }

    .image-frame.tall img {
      aspect-ratio: 3 / 4.15;
    }

    .caption {
      padding: 12px 14px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
      background: white;
    }

    .note {
      padding: 16px;
      border-left: 4px solid var(--gold);
      border-radius: var(--radius);
      background: #fff7df;
      color: #705b20;
      font-weight: 800;
      line-height: 1.6;
    }

    .care-list {
      display: grid;
      gap: 11px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .care-list li {
      display: grid;
      grid-template-columns: 34px 1fr;
      gap: 12px;
      align-items: start;
      padding: 13px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: white;
      color: var(--ink);
      font-weight: 800;
      line-height: 1.45;
    }

    .care-list b {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: white;
      background: linear-gradient(135deg, var(--sage), var(--aqua));
    }

    .therapy-card {
      display: grid;
      gap: 13px;
    }

    .therapy-tag {
      width: max-content;
      max-width: 100%;
      padding: 7px 10px;
      border-radius: 999px;
      color: #216c68;
      background: var(--sage-2);
      font-size: 11px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .gallery-item {
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: white;
      box-shadow: var(--shadow-soft);
    }

    .gallery-item img {
      width: 100%;
      aspect-ratio: 4 / 3.6;
      object-fit: cover;
    }

    .gallery-item.portrait img {
      aspect-ratio: 3 / 4.1;
    }

    .video-card {
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: white;
      box-shadow: var(--shadow-soft);
    }

    .video-card video {
      width: 100%;
      aspect-ratio: 9 / 16;
      background: #0f2428;
      object-fit: cover;
    }

    .video-card-body {
      padding: 16px;
    }

    .video-card-body h3 {
      margin-bottom: 7px;
      color: var(--ink);
      font-size: 18px;
    }

    .video-card-body p {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .quote-mark {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: white;
      background: linear-gradient(135deg, var(--coral), #cb5f9a);
      font-family: "Playfair Display", Georgia, serif;
      font-size: 30px;
      line-height: 1;
    }

    .testimonial-card {
      display: grid;
      gap: 14px;
    }

    .testimonial-card strong {
      color: var(--ink);
      font-size: 14px;
    }

    .testimonial-card span {
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
    }

    .boss-message {
      padding: 24px;
      border: 1px solid rgba(233, 120, 98, .28);
      border-radius: var(--radius);
      background:
        linear-gradient(135deg, rgba(255, 240, 236, .96), rgba(255, 255, 255, .96));
      box-shadow: var(--shadow);
    }

    .boss-message p {
      color: var(--ink);
      font-size: 17px;
      line-height: 1.75;
    }

    .signature {
      margin-top: 18px;
      color: var(--ink);
      font-family: "Playfair Display", Georgia, serif;
      font-size: 28px;
      font-weight: 800;
    }

    .plan-panel {
      display: grid;
      gap: 16px;
      padding: 22px;
      border: 1px solid rgba(43, 184, 178, .28);
      border-radius: var(--radius);
      background:
        linear-gradient(135deg, rgba(223, 241, 235, .88), rgba(255, 255, 255, .96));
      box-shadow: var(--shadow);
    }

    .plan-panel h3 {
      margin: 0;
      color: var(--ink);
      font-family: "Playfair Display", Georgia, serif;
      font-size: clamp(28px, 6vw, 44px);
      line-height: 1.05;
    }

    .plan-panel p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .blog-toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 18px;
    }

    .filter-btn {
      min-height: 38px;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 0 13px;
      color: var(--ink);
      background: white;
      font-size: 13px;
      font-weight: 900;
      cursor: pointer;
    }

    .filter-btn.is-active {
      color: white;
      border-color: transparent;
      background: var(--ink);
    }

    .blog-card {
      display: grid;
      gap: 12px;
    }

    .blog-card small {
      color: var(--sage);
      font-weight: 900;
      text-transform: uppercase;
    }

    .form-wrap {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 22px;
      align-items: start;
    }

    .form-panel {
      padding: 22px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: white;
      box-shadow: var(--shadow);
    }

    .form-grid {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    .field {
      display: grid;
      gap: 7px;
    }

    .field label {
      color: var(--ink);
      font-size: 13px;
      font-weight: 900;
    }

    .field input,
    .field select,
    .field textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 13px 14px;
      color: var(--ink);
      background: #fbfffe;
      outline: none;
    }

    .field textarea {
      min-height: 110px;
      resize: vertical;
    }

    .field input:focus,
    .field select:focus,
    .field textarea:focus {
      border-color: var(--aqua);
      box-shadow: 0 0 0 4px rgba(43, 184, 178, .12);
    }

    .form-note {
      margin-top: 12px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }

    .map-card {
      display: grid;
      gap: 14px;
      padding: 22px;
      border-radius: var(--radius);
      color: white;
      background:
        linear-gradient(135deg, rgba(23, 59, 66, .96), rgba(45, 111, 107, .94));
      box-shadow: var(--shadow);
    }

    .map-card h3 {
      margin: 0;
      color: white;
      font-family: "Playfair Display", Georgia, serif;
      font-size: 35px;
      line-height: 1.05;
    }

    .map-card p {
      margin: 0;
      color: rgba(255, 255, 255, .82);
      line-height: 1.7;
    }

    .emergency-note {
      padding: 18px;
      border: 1px solid rgba(233, 120, 98, .3);
      border-radius: var(--radius);
      background: var(--rose);
      color: #76372b;
      font-size: 14px;
      font-weight: 800;
      line-height: 1.6;
    }

    .sources {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
    }

    .sources a {
      color: var(--ink);
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .footer {
      padding: 34px 0 104px;
      color: rgba(255, 255, 255, .78);
      background: var(--ink);
      font-size: 14px;
      line-height: 1.7;
    }

    .footer-grid {
      display: grid;
      gap: 18px;
    }

    .footer b {
      display: block;
      margin-bottom: 8px;
      color: white;
      font-size: 16px;
    }

    .footer a {
      color: white;
      font-weight: 900;
    }

    .floating-wa {
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 60;
      min-height: 56px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 20px;
      border-radius: 999px;
      color: white;
      background: #20c767;
      box-shadow: 0 16px 42px rgba(23, 59, 66, .24);
      font-weight: 900;
    }

    @media (min-width: 720px) {
      .hero-actions,
      .quick-routes,
      .trust-row {
        display: flex;
        flex-wrap: wrap;
      }

      .route-card {
        min-width: 240px;
        flex: 1;
      }

      .grid-2,
      .testimonial-grid,
      .equipment-grid,
      .faq-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .grid-3,
      .blog-grid,
      .gallery-grid {
